{
  "name": "fastify-auth-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Fastify boilerplate with Drizzle ORM and authentication",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node src/db/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bcrypt"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "@isaacs/brace-expansion@<5.0.1": ">=5.0.1",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "brace-expansion@4.0.1": ">=5.0.5",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@<2.8.3": ">=2.8.3",
      "ajv@<8.18.0": ">=8.18.0",
      "bn.js@<4.12.3": ">=4.12.3",
      "lodash@<4.17.23": ">=4.17.23",
      "valibot@<1.2.0": ">=1.2.0",
      "effect@<3.20.0": ">=3.20.0",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "flatted@<3.4.2": ">=3.4.2",
      "handlebars@<4.7.9": ">=4.7.9",
      "diff@<4.0.4": ">=4.0.4",
      "hono@<4.9.7": ">=4.9.7",
      "hono@>=1.1.0 <4.10.2": ">=4.10.2",
      "hono@<4.10.3": ">=4.10.3",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "js-yaml": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0"
    }
  }
}
