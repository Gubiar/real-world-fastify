                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Invalid credentials error shape', function () {",
                  "  pm.expect(jsonData.success).to.eql(false);",
                  "  pm.expect(jsonData.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "response": []
