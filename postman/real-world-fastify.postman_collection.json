{
  "info": {
    "_postman_id": "d7a57bb8-0ee0-4d9a-b9c5-9f2145ba4f5a",
    "name": "Real-World Fastify API",
    "description": "Collection para testar os endpoints da API Fastify com fluxo de autenticacao JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "email",
      "value": "postman.user@example.com"
    },
    {
      "key": "password",
      "value": "Password123"
    },
    {
      "key": "name",
      "value": "Postman User"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Health payload is ok', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 400 (duplicate)', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.test('Register success format', function () {",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data.email).to.eql(pm.collectionVariables.get('email'));",
                  "  });",
                  "} else {",
                  "  pm.test('Duplicate user error format', function () {",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Login response contains token', function () {",
                  "  pm.expect(jsonData.success).to.eql(true);",
                  "  pm.expect(jsonData.data.token).to.be.a('string');",
                  "});",
                  "",
                  "pm.collectionVariables.set('token', jsonData.data.token);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('/me returns authenticated user payload', function () {",
                  "  pm.expect(jsonData.success).to.eql(true);",
                  "  pm.expect(jsonData.data.email).to.eql(pm.collectionVariables.get('email'));",
                  "  pm.expect(jsonData.data.userId).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
