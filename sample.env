# Server configuration
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# Database
# Development: postgresql://admin:admin@localhost:5432/mydb
# Test:        postgresql://admin:admin@localhost:5433/mydb_test
DATABASE_URL="postgresql://admin:admin@localhost:5432/mydb"
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=5000

# Authentication
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-required"
JWT_EXPIRES_IN="1d"

# Security - CORS (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Security - Bcrypt
BCRYPT_ROUNDS=12

# Security - Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW="15 minutes"

# Logging
LOG_LEVEL="info"