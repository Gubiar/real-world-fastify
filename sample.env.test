# Test Environment Configuration
# Copy this to .env.test and adjust as needed

NODE_ENV=test
PORT=3001
HOST=0.0.0.0

# Test Database (separate from development)
DATABASE_URL=postgresql://admin:admin@localhost:5433/mydb_test
DB_POOL_MIN=2
DB_POOL_MAX=5
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=5000

# JWT (less secure for tests, faster)
JWT_SECRET=test-jwt-secret-minimum-32-characters-for-security-validation-in-tests
JWT_EXPIRES_IN=1d

# CORS (permissive for tests)
CORS_ORIGIN=*

# Bcrypt (lower rounds for faster tests)
BCRYPT_ROUNDS=10

# Rate Limiting (higher limits for tests)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_AUTH_WINDOW=1 minute

# Logging (minimal for tests)
LOG_LEVEL=error

